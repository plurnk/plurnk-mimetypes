{
    "name": "{{PACKAGE_NAME}}",
    "version": "0.0.0",
    "description": "{{MIMETYPE}} mimetype handler for plurnk-service.",
    "type": "module",
    "license": "MIT",
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "node": ">=25"
    },
    "plurnk": {
        "kind": "mimetype",
        "name": "{{MIMETYPE}}",
        "glyph": "{{GLYPH}}",
        "extensions": {{EXTENSIONS}}
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist/**/*",
        "README.md"
    ],
    "scripts": {
        "test:lint": "tsc --noEmit",
        "test:unit": "node --test src/**/*.test.ts",
        "test": "npm run test:lint && npm run test:unit",
        "build:dist": "tsc -p tsconfig.build.json",
        "build": "npm run build:dist",
        "prepare": "npm run build"
    },
    "dependencies": {
        "@plurnk/plurnk-mimetypes": "{{PLURNK_MIMETYPES_VERSION}}"
    },
    "devDependencies": {
        "@types/node": "^25.8.0",
        "typescript": "^6.0.3"
    }
}
