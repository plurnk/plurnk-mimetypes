# @plurnk/plurnk-mimetypes — environment
# Family-prefix convention: every mimetypes-family knob is PLURNK_MIMETYPES_*.

# Root directory holding the side-by-side @plurnk/plurnk-mimetypes-grammar-*
# repos, used by the grammar maintenance scripts (grammars:check /
# grammars:update / grammars:publish). Defaults to this checkout's parent
# (the usual layout where every plurnk repo is cloned side by side).
#
# PLURNK_MIMETYPES_GRAMMARS_ROOT=..

# Root directory holding the side-by-side @plurnk/plurnk-mimetypes-* repos,
# scanned by deps:check (first-party exact-pin freshness + per-package npm audit).
# Defaults to this checkout's parent — same layout as PLURNK_MIMETYPES_GRAMMARS_ROOT.
#
# PLURNK_MIMETYPES_FAMILY_ROOT=..

# Minimum npm-audit severity deps:check flags (info|low|moderate|high|critical).
# Defaults to moderate.
#
# PLURNK_MIMETYPES_AUDIT_LEVEL=moderate
