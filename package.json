{
  "name": "@possumtech/antlrmap",
  "version": "0.1.1",
  "description": "Use antlr4 to generate repomaps for llm agent context",
  "keywords": [
    "repomap"
  ],
  "homepage": "https://github.com/possumtech/antlrmap#readme",
  "bugs": {
    "url": "https://github.com/possumtech/antlrmap/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/possumtech/antlrmap.git"
  },
  "engines": {
    "node": ">=25"
  },
  "license": "MIT",
  "author": "@wikitopian",
  "type": "module",
  "main": "lib/antlrmap.js",
  "exports": {
    ".": "./lib/antlrmap.js"
  },
  "bin": {
    "antlrmap": "lib/index.js",
    "plurnk-mimetypes-compile": "./bin/plurnk-mimetypes-compile.js"
  },
  "files": [
    "lib/antlrmap.js",
    "lib/index.js",
    "lib/Parser.js",
    "lib/Formatter.js",
    "languages/*/map.js",
    "languages/*/package.json",
    "languages/*/generated/**/*.js"
  ],
  "workspaces": [
    "languages/*"
  ],
  "scripts": {
    "scaffold": "node scripts/scaffold.js",
    "init-language": "node scripts/init-language.js",
    "build:legacy": "node scripts/compile.js",
    "build:dist": "tsc -p tsconfig.build.json",
    "build": "npm run build:dist",
    "test:lint": "tsc --noEmit",
    "test:unit": "node --test src/**/*.test.ts",
    "test:intg": "node --test test/integration/**/*.test.ts",
    "test:legacy": "node --test test/e2e/**/*.test.js",
    "test:languages": "node --test languages/*/map.test.js",
    "test:all": "node --test test/e2e/**/*.test.js languages/*/map.test.js",
    "test": "npm run test:lint && npm run test:unit && npm run test:intg && npm run test:legacy",
    "release": "npm version patch && git push --follow-tags"
  },
  "dependencies": {
    "antlr4": "^4.13.2"
  },
  "peerDependencies": {
    "antlr4ng": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "antlr4ng": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "antlr-ng": "^1.0.10",
    "antlr4ng": "^3.0.0",
    "typescript": "^6.0.3"
  }
}
