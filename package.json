{
    "name": "@plurnk/plurnk-mimetypes",
    "version": "0.15.17",
    "description": "Framework + detection service for the @plurnk/plurnk-mimetypes-* handler family.",
    "keywords": [
        "plurnk",
        "mimetype",
        "llm",
        "symbols",
        "structural"
    ],
    "homepage": "https://github.com/plurnk/plurnk-mimetypes#readme",
    "bugs": {
        "url": "https://github.com/plurnk/plurnk-mimetypes/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/plurnk/plurnk-mimetypes.git"
    },
    "engines": {
        "node": ">=25"
    },
    "license": "MIT",
    "author": "@wikitopian",
    "type": "module",
    "publishConfig": {
        "access": "public"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./conformance": {
            "types": "./dist/conformance.d.ts",
            "default": "./dist/conformance.js"
        },
        "./package.json": "./package.json"
    },
    "bin": {
        "plurnk-mimetypes-compile": "./bin/plurnk-mimetypes-compile.js"
    },
    "files": [
        "dist/**/*",
        "bin/*.js",
        "README.md",
        "SPEC.md"
    ],
    "scripts": {
        "build:dist": "tsc -p tsconfig.build.json",
        "build": "npm run build:dist",
        "prepare": "npm run build",
        "test:lint": "tsc --noEmit",
        "test:unit": "node --test src/*.test.ts src/treesitter/*.test.ts src/issues/*.test.ts",
        "test:intg": "node --test test/integration/**/*.test.ts",
        "test": "npm run test:lint && npm run test:unit && npm run test:intg && npm run test:conf",
        "test:conf": "node --test test/conformance/*.test.ts"
    },
    "peerDependencies": {
        "antlr-ng": "^1.0.10"
    },
    "peerDependenciesMeta": {
        "antlr-ng": {
            "optional": true
        }
    },
    "devDependencies": {
        "@plurnk/plurnk-mimetypes-grammar-css": "0.1.0",
        "@tree-sitter-grammars/tree-sitter-kotlin": "^1.1.0",
        "@tree-sitter-grammars/tree-sitter-lua": "^0.4.1",
        "@tree-sitter-grammars/tree-sitter-toml": "^0.7.0",
        "@tree-sitter-grammars/tree-sitter-yaml": "^0.7.1",
        "@tree-sitter-grammars/tree-sitter-zig": "^1.1.2",
        "@types/node": "^25.8.0",
        "antlr4ng": "^3.0.16",
        "tree-sitter-bash": "^0.25.1",
        "tree-sitter-c": "^0.24.1",
        "tree-sitter-cpp": "^0.23.4",
        "tree-sitter-dart": "^1.0.0",
        "tree-sitter-elixir": "^0.3.5",
        "tree-sitter-fsharp": "^0.1.0",
        "tree-sitter-go": "^0.25.0",
        "tree-sitter-haskell": "^0.23.1",
        "tree-sitter-java": "^0.23.5",
        "tree-sitter-javascript": "^0.25.0",
        "tree-sitter-julia": "^0.23.1",
        "tree-sitter-make": "^1.1.1",
        "tree-sitter-ocaml": "^0.24.2",
        "tree-sitter-odin": "^1.3.0",
        "tree-sitter-php": "^0.24.2",
        "tree-sitter-python": "^0.25.0",
        "tree-sitter-ruby": "^0.23.1",
        "tree-sitter-rust": "^0.24.0",
        "tree-sitter-scala": "^0.24.0",
        "tree-sitter-typescript": "^0.23.2",
        "typescript": "^6.0.3",
        "web-tree-sitter": "^0.25.10"
    },
    "dependencies": {
        "@plurnk/plurnk-mimetypes-application-json": "0.5.2",
        "@plurnk/plurnk-mimetypes-application-xml": "0.1.2",
        "@plurnk/plurnk-mimetypes-text-csv": "0.4.2",
        "@plurnk/plurnk-mimetypes-text-html": "0.6.2",
        "@plurnk/plurnk-mimetypes-text-markdown": "0.6.2",
        "@plurnk/plurnk-mimetypes-text-plain": "0.7.2",
        "@xmldom/xmldom": "^0.9.10",
        "antlr4ng": "^3.0.16",
        "jsonpath-plus": "^10.4.0",
        "smol-toml": "^1.6.1",
        "web-tree-sitter": "^0.25.10",
        "xpath": "^0.0.34",
        "yaml": "^2.9.0"
    }
}
