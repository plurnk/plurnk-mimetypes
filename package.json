{
  "name": "@possumtech/antlrmap",
  "version": "0.0.1",
  "description": "Use antlr4 to generate repomaps for llm agent context",
  "keywords": [
    "repomap"
  ],
  "homepage": "https://github.com/possumtech/antlrmap#readme",
  "bugs": {
    "url": "https://github.com/possumtech/antlrmap/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/possumtech/antlrmap.git"
  },
  "license": "MIT",
  "author": "@wikitopian",
  "type": "module",
  "main": "lib/index.js",
  "bin": {
    "antlrmap": "lib/index.js"
  },
  "files": [
    "lib/"
  ],
  "workspaces": [
    "languages/*"
  ],
  "scripts": {
    "scaffold": "node scripts/scaffold.js",
    "build": "npm run build --workspaces --if-present",
    "lint": "npx @biomejs/biome check .",
    "test": "node --test test/**/*.test.js"
  },
  "dependencies": {
    "antlr4": "^4.13.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "antlr-ng": "^1.0.10"
  }
}
