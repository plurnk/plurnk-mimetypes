{
  "name": "@plurnk/plurnk-mimetypes",
  "version": "0.2.1",
  "description": "Framework + detection service for the @plurnk/plurnk-mimetypes-* handler family.",
  "keywords": [
    "plurnk",
    "mimetype",
    "llm",
    "symbols",
    "structural"
  ],
  "homepage": "https://github.com/plurnk/plurnk-mimetypes#readme",
  "bugs": {
    "url": "https://github.com/plurnk/plurnk-mimetypes/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/plurnk/plurnk-mimetypes.git"
  },
  "engines": {
    "node": ">=25"
  },
  "license": "MIT",
  "author": "@wikitopian",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "plurnk-mimetypes-compile": "./bin/plurnk-mimetypes-compile.js"
  },
  "files": [
    "dist/**/*",
    "bin/*.js",
    "README.md",
    "SPEC.md"
  ],
  "workspaces": [
    "languages/*"
  ],
  "scripts": {
    "scaffold": "node scripts/scaffold.js",
    "init-language": "node scripts/init-language.js",
    "build:legacy": "node scripts/compile.js",
    "build:dist": "tsc -p tsconfig.build.json",
    "build": "npm run build:dist",
    "prepare": "npm run build",
    "test:lint": "tsc --noEmit",
    "test:unit": "node --test src/**/*.test.ts",
    "test:intg": "node --test test/integration/**/*.test.ts",
    "test:legacy": "node --test test/e2e/**/*.test.js",
    "test:languages": "node --test languages/*/map.test.js",
    "test:all": "node --test test/e2e/**/*.test.js languages/*/map.test.js",
    "test": "npm run test:lint && npm run test:unit && npm run test:intg && npm run test:legacy"
  },
  "peerDependencies": {
    "antlr-ng": "^1.0.10",
    "antlr4ng": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "antlr-ng": {
      "optional": true
    },
    "antlr4ng": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "antlr-ng": "^1.0.10",
    "antlr4": "^4.13.2",
    "antlr4ng": "^3.0.0",
    "typescript": "^6.0.3"
  }
}
